# Supabase Configuration
# Get these values from your Supabase project settings:
# - Project URL: https://app.supabase.com/project/_/settings/api
# - API Keys: https://app.supabase.com/project/_/settings/api

# Supabase project URL (e.g., https://wuvkrgdanofccsqpdosv.supabase.co)
SUPABASE_URL=your_supabase_project_url

# Supabase Anon Key (public, used in client-side code)
# Found in Project Settings > API > Project API keys > anon/public
SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (secret, used in server-side code only)
# Found in Project Settings > API > Project API keys > service_role
# WARNING: Never expose this key in client-side code!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin Authentication
# Set a strong password for admin access to the dashboard
ADMIN_PASSWORD=your_secure_admin_password

# JWT Secret for session tokens
# Generate a random secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key

# Google Gemini API Key (for AI chat and recommendations)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Node Environment
NODE_ENV=development
